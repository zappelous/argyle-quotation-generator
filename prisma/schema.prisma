generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Template {
  id              String      @id @default(cuid())
  name            String      // e.g. "Argyle Solar", "Generic Proforma"
  isDefault       Boolean     @default(false)

  // Company info
  companyName     String
  companyUen      String?
  companyAddress  String
  companyPhone    String?
  companyEmail    String
  companyLogo     String?     // base64 data URL
  contactPerson   String?

  // Bank details
  bankName        String?
  bankAccount     String?
  bankAddress     String?
  swiftCode       String?
  bankCurrency    String      @default("SGD")

  // Styling
  primaryColor    String      @default("#1e293b") // slate-900
  secondaryColor  String      @default("#64748b") // slate-500
  accentColor     String      @default("#0f172a") // slate-950
  fontFamily      String      @default("Helvetica")

  // Layout options
  showLogo        Boolean     @default(true)
  showUen         Boolean     @default(true)
  showBankDetails Boolean     @default(true)
  showSignatures  Boolean     @default(true)
  headerStyle     String      @default("standard") // standard, minimal, banner
  tableStyle      String      @default("bordered")  // bordered, minimal, striped

  // Default terms
  defaultDeliveryTerms  String?
  defaultPaymentTerms   String?
  defaultWarranty       String?

  // Currency & tax
  currency        String      @default("SGD")
  taxRate         Decimal     @default(0.00) @db.Decimal(5, 2)
  taxName         String      @default("GST")

  // Default customer for this template
  defaultCustomerId String?
  defaultCustomer   Customer?   @relation(fields: [defaultCustomerId], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  quotations      Quotation[]
  invoices        Invoice[]
  skus            TemplateSKU[]
}

model TemplateSKU {
  id            String    @id @default(cuid())
  template      Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId    String
  sku           SKU       @relation(fields: [skuId], references: [id], onDelete: Cascade)
  skuId         String
  customPrice   Decimal?  @db.Decimal(10, 2) // override price per template
  customName    String?   // override display name
  isActive      Boolean   @default(true)

  @@unique([templateId, skuId])
}

model Customer {
  id          String      @id @default(cuid())
  name        String
  email       String
  phone       String?
  address     String
  uen         String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  quotations  Quotation[]
  invoices    Invoice[]
  templates   Template[]  // Templates that default to this customer
}

model SKU {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  description   String?
  model         String?
  performance   String?
  unitPrice     Decimal         @db.Decimal(10, 2)
  imageUrl      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  quotationItems QuotationItem[]
  invoiceItems   InvoiceItem[]
  templateSKUs   TemplateSKU[]
}

model Quotation {
  id            String          @id @default(cuid())
  quotationNo   String          @unique
  issueDate     DateTime        @default(now())
  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId    String
  template      Template        @relation(fields: [templateId], references: [id])
  templateId    String
  items         QuotationItem[]
  subtotal      Decimal         @db.Decimal(10, 2)
  taxRate       Decimal         @default(0.00) @db.Decimal(5, 2)
  taxAmount     Decimal         @db.Decimal(10, 2)
  total         Decimal         @db.Decimal(10, 2)
  deliveryTerms String?
  paymentTerms  String?
  warranty      String?
  dispatchDate  String?
  status        String          @default("draft") // draft, sent, accepted
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  invoices      Invoice[]
}

model QuotationItem {
  id            String      @id @default(cuid())
  quotation     Quotation   @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId   String
  sku           SKU         @relation(fields: [skuId], references: [id], onDelete: Cascade)
  skuId         String
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  amount        Decimal     @db.Decimal(10, 2)
  description   String?     // override from SKU description
  displayName   String      // name shown on quotation
  lineNo        Int
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNo     String    @unique
  issueDate     DateTime  @default(now())
  dueDate       DateTime?
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId    String
  template      Template  @relation(fields: [templateId], references: [id])
  templateId    String
  quotation     Quotation? @relation(fields: [quotationId], references: [id])
  quotationId   String?

  items         InvoiceItem[]
  subtotal      Decimal   @db.Decimal(10, 2)
  taxRate       Decimal   @default(0.00) @db.Decimal(5, 2)
  taxAmount     Decimal   @db.Decimal(10, 2)
  total         Decimal   @db.Decimal(10, 2)
  amountPaid    Decimal   @default(0.00) @db.Decimal(10, 2)
  balanceDue    Decimal   @db.Decimal(10, 2)

  // Milestone info
  milestone     String?   // e.g. "Downpayment", "Installation", "Final Collection"
  milestonePct  Decimal   @default(100.00) @db.Decimal(5, 2)

  deliveryTerms String?
  paymentTerms  String?
  warranty      String?
  notes         String?
  status        String    @default("draft") // draft, sent, partial, paid, overdue, cancelled

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  payments      Payment[]
}

model InvoiceItem {
  id            String    @id @default(cuid())
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId     String
  sku           SKU       @relation(fields: [skuId], references: [id], onDelete: Cascade)
  skuId         String
  quantity      Int
  unitPrice     Decimal   @db.Decimal(10, 2)
  amount        Decimal   @db.Decimal(10, 2)
  description   String?
  displayName   String
  lineNo        Int
}

model Payment {
  id            String    @id @default(cuid())
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId     String
  amount        Decimal   @db.Decimal(10, 2)
  paymentDate   DateTime  @default(now())
  paymentMethod String    @default("Bank Transfer")
  referenceNo   String?
  notes         String?
  createdAt     DateTime  @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
